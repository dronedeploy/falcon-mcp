---
// Hero section with animations — uses Starlight CSS variables for theming
---

<div class="hero">
  <!-- Animated geometric grid background -->
  <div class="hero-bg">
    <div class="grid-lines"></div>
    <div class="grid-glow"></div>
  </div>

  <div class="hero-content anim-fade-up" style="--delay: 0s">
    <img src="/falcon-mcp/icons/cs-logo-dark.png" alt="CrowdStrike" class="hero-logo hero-logo-dark" />
    <img src="/falcon-mcp/icons/cs-logo-light.png" alt="CrowdStrike" class="hero-logo hero-logo-light" />
    <h1 class="hero-title">
      <span class="hero-falcon">Falcon</span> MCP Server
    </h1>
    <p class="hero-tagline">
      <span class="tagline-text"></span><span class="cursor">|</span>
    </p>
    <div class="hero-actions anim-fade-up" style="--delay: 1.8s">
      <a href="/falcon-mcp/getting-started/installation/" class="hero-btn hero-btn-primary">
        Get Started
      </a>
      <a href="https://github.com/CrowdStrike/falcon-mcp" class="hero-btn hero-btn-secondary">
        View on GitHub
      </a>
    </div>
  </div>

  <div class="hero-features">
    <div class="feature-card anim-slide-up" style="--delay: 2.2s">
      <div class="feature-icon">
        <img src="/falcon-mcp/icons/overwatch.png" alt="" width="28" height="28" />
      </div>
      <div class="feature-label">Security at Scale</div>
      <p>Query hosts, detections, and vulnerabilities across your entire fleet</p>
    </div>
    <div class="feature-card anim-slide-up" style="--delay: 2.4s">
      <div class="feature-icon">
        <img src="/falcon-mcp/icons/search-engine.png" alt="" width="28" height="28" />
      </div>
      <div class="feature-label">AI-Native</div>
      <p>Purpose-built for LLM tool use via the Model Context Protocol</p>
    </div>
    <div class="feature-card anim-slide-up" style="--delay: 2.6s">
      <div class="feature-icon">
        <img src="/falcon-mcp/icons/servers.png" alt="" width="28" height="28" />
      </div>
      <div class="feature-label">Deploy Anywhere</div>
      <p>stdio, SSE, and streamable-HTTP for any environment</p>
    </div>
  </div>

</div>

<script>
  const taglineText = 'Connect AI assistants to the CrowdStrike Falcon platform.';
  const taglineEl = document.querySelector('.tagline-text');
  const alreadyPlayed = sessionStorage.getItem('heroAnimPlayed');

  if (alreadyPlayed) {
    // Show everything instantly — no entrance animations
    document.querySelectorAll('.anim-slide-up, .anim-fade-up').forEach(el => {
      (el as HTMLElement).style.transition = 'none';
      el.classList.add('visible');
    });
    taglineEl!.textContent = taglineText;
  } else {
    // Typewriter effect for tagline
    let i = 0;
    function typeWriter() {
      if (i < taglineText.length) {
        taglineEl!.textContent += taglineText.charAt(i);
        i++;
        setTimeout(typeWriter, 30);
      } else {
        sessionStorage.setItem('heroAnimPlayed', '1');
      }
    }

    // Start typing after title animation
    setTimeout(typeWriter, 600);

    // Intersection Observer for scroll-triggered card animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.anim-slide-up, .anim-fade-up').forEach(el => {
      observer.observe(el);
    });
  }

</script>

<style>
  /* ===== Hero container ===== */
  .hero {
    position: relative;
    padding: 4rem 2rem 3rem;
    text-align: center;
    overflow: hidden;
  }

  /* ===== Animated geometric grid background ===== */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .grid-lines {
    position: absolute;
    inset: -50%;
    background-image:
      linear-gradient(color-mix(in srgb, var(--sl-color-accent) 6%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--sl-color-accent) 6%, transparent) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: gridDrift 20s linear infinite;
  }

  .grid-glow {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, color-mix(in srgb, var(--sl-color-accent) 8%, transparent) 0%, transparent 70%);
    animation: glowPulse 4s ease-in-out infinite;
  }

  @keyframes gridDrift {
    0% { transform: translate(0, 0); }
    100% { transform: translate(60px, 60px); }
  }

  @keyframes glowPulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  /* ===== Entrance animations ===== */
  .anim-fade-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: var(--delay, 0s);
  }

  .anim-fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .anim-slide-up {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--delay, 0s);
  }

  .anim-slide-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== Hero content ===== */
  .hero-logo {
    display: block;
    max-width: 280px;
    height: auto;
    margin: 0 auto 1.5rem;
  }

  .hero-logo-light {
    display: none !important;
  }

  .hero-content {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 1rem;
    color: var(--sl-color-white);
  }

  .hero-falcon {
    color: var(--sl-color-accent);
  }

  /* ===== Typewriter tagline ===== */
  .hero-tagline {
    font-size: 1.25rem;
    color: var(--sl-color-gray-2);
    margin: 0 0 2rem;
    line-height: 1.5;
    min-height: 1.875rem;
  }

  .cursor {
    display: inline-block;
    color: var(--sl-color-accent);
    animation: blink 1s step-end infinite;
    font-weight: 300;
    margin-left: 1px;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ===== Buttons ===== */
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .hero-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    font-weight: 700;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
    text-decoration: none !important;
    transition: all 0.25s ease;
  }

  .hero-btn-primary {
    background: var(--sl-color-accent);
    color: var(--sl-color-white) !important;
    border: 2px solid var(--sl-color-accent);
    box-shadow: 0 0 0 0 transparent;
  }

  .hero-btn-primary:hover {
    background: var(--sl-color-accent-high);
    border-color: var(--sl-color-accent-high);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
    transform: translateY(-1px);
  }

  .hero-btn-secondary {
    background: transparent;
    color: var(--sl-color-accent) !important;
    border: 2px solid var(--sl-color-accent);
  }

  .hero-btn-secondary:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--sl-color-accent) 20%, transparent);
    transform: translateY(-1px);
  }

  /* ===== Feature cards — equal height with aligned content ===== */
  .hero-features {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: stretch;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto 3rem;
  }

  .feature-card {
    background: var(--sl-color-gray-6);
    border-left: 3px solid var(--sl-color-accent);
    padding: 1.5rem;
    text-align: left;
    border-radius: 4px;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-sizing: border-box;
    margin: 0 !important;
  }

  .feature-card:hover {
    background: var(--sl-color-gray-5);
    box-shadow: 0 0 30px color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    transform: translateY(-2px);
  }

  .feature-icon {
    color: var(--sl-color-accent);
    line-height: 1;
    height: 28px;
    margin-bottom: 0.75rem;
  }

  .feature-label {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--sl-color-white);
    margin: 0 0 0.5rem;
  }

  .feature-card p {
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    margin: 0;
    line-height: 1.5;
  }

  /* ===== Responsive ===== */
  @media (max-width: 700px) {
    .hero-features {
      grid-template-columns: 1fr;
    }
  }

  /* ===== Light mode — logo switching only ===== */
  :global([data-theme='light']) .hero-logo-dark {
    display: none;
  }

  :global([data-theme='light']) .hero-logo-light {
    display: block !important;
  }

</style>
